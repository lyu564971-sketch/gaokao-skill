# 环境变量示例（复制为 .env 并填入真实值）

# ============ LLM Provider ============
# 选用的 LLM provider 名（当前支持 glm）
LLM_PROVIDER=glm
# OpenAI 兼容接口地址（GLM/通义/Kimi/DeepSeek 均可）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your-api-key-here
LLM_MODEL=glm-4.6

# ============ Data Provider ============
# 选用的数据 provider 名（当前支持 zai-websearch）
DATA_PROVIDER=zai-websearch
# 搜索后端类型：auto（默认，按已配置项自动判定）/ http / tavily / fallback
#   - http：通用 JSON 搜索接口（需配 DATA_SEARCH_ENDPOINT）
#   - tavily：Tavily Search API（需配 DATA_SEARCH_API_KEY）
#   - fallback：CLI 演示模式（NONE 级占位）
DATA_SEARCH_BACKEND=auto
# WebSearch 接口地址（http 后端用，留空则走 tavily 或 fallback）
DATA_SEARCH_ENDPOINT=
# 接口 API Key（http 后端作 Bearer；tavily 后端作 api_key）
DATA_SEARCH_API_KEY=
